PORT=3100

# Required for indexing + search
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embeddings (at least one)
OPENAI_API_KEY=
LOVABLE_API_KEY=

# Optional — higher GitHub API rate limits + private repos
GITHUB_TOKEN=

# Optional — LLM answer synthesis (defaults to gpt-4o-mini)
ORG_MEMORY_LLM_MODEL=gpt-4o-mini

# Optional — secure service when exposed publicly
ORG_MEMORY_SERVICE_KEY=
